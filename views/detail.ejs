<div class="detail-page">
  <div class="detail-back">
    <a href="/" class="back-link">
      <i class="bi bi-chevron-left"></i> Back to Notes
    </a>
  </div>

  <div class="detail-content">
    <!-- Action buttons always visible at top right -->
    <div class="detail-actions-top">
      <a href="/notes/<%= note.id %>/edit" class="btn-edit">
        <i class="bi bi-pencil-fill"></i> Edit
      </a>
      <form action="/notes/<%= note.id %>/delete" method="POST" style="display:inline"
            onsubmit="return confirm('Hapus catatan ini?')">
        <button type="submit" class="btn-delete">
          <i class="bi bi-trash-fill"></i>
        </button>
      </form>
    </div>

    <div class="detail-body">
      <h1 class="detail-title"><%= note.title %></h1>
      <p class="detail-date">
        <%= new Date(note.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
      </p>

      <% if (note.images && note.images.length > 0) { %>
      <div class="detail-images">
        <% note.images.forEach(img => { %>
        <div class="detail-image-wrapper">
          <img src="<%= img.url %>" alt="<%= note.title %>" class="detail-image">
        </div>
        <% }) %>
      </div>
      <% } %>

      <div class="detail-text">
        <%- note.content.split('\n').join('<br>') %>
      </div>
    </div>

    <% if (note.tags && note.tags.length > 0) { %>
    <div class="detail-tags">
      <span class="tagged-in-label">TAGGED IN:</span>
      <% note.tags.forEach((tag, i) => { %>
      <a href="/?tag=<%= encodeURIComponent(tag.name) %>" class="detail-tag-pill tag-color-<%= i % 6 %>">
        <%= tag.name.toUpperCase() %>
      </a>
      <% }) %>
      <a href="/notes/<%= note.id %>/edit" class="detail-tag-add" title="Edit tags">
        <i class="bi bi-plus"></i>
      </a>
    </div>
    <% } %>

    <% if (note.links && note.links.length > 0) { %>
    <div class="detail-links">
      <span class="tagged-in-label">LINKS:</span>
      <% note.links.forEach(link => { %>
      <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" class="detail-link-item">
        <i class="bi bi-link-45deg"></i> <%= link.url %>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>
